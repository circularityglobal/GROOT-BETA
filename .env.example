# =============================================================================
# REFINET Cloud — Environment Variables
# Copy to .env and fill in values. NEVER commit .env to version control.
# =============================================================================

# Core identity
REFINET_ENV=production
REFINET_DOMAIN=api.refinet.io
REFINET_FRONTEND_URL=https://app.refinet.io

# Security — generate with: python3 -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=CHANGE_ME_64_BYTE_HEX
REFRESH_SECRET=CHANGE_ME_64_BYTE_HEX
SERVER_PEPPER=CHANGE_ME_64_BYTE_HEX

# Signing keys — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
WEBHOOK_SIGNING_KEY=CHANGE_ME_32_BYTE_HEX
INTERNAL_DB_ENCRYPTION_KEY=CHANGE_ME_32_BYTE_HEX
ADMIN_API_SECRET=CHANGE_ME_32_BYTE_HEX

# JWT
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Databases (SQLite, WAL mode)
PUBLIC_DB_URL=sqlite:////opt/refinet/data/public.db
INTERNAL_DB_URL=sqlite:////opt/refinet/data/internal.db

# ── Model Providers ──────────────────────────────────────────────

# BitNet (sovereign, CPU-native — always available)
BITNET_HOST=http://127.0.0.1:8080

# Default model for inference
DEFAULT_MODEL=bitnet-b1.58-2b

# Fallback chain — providers tried in order when primary fails
PROVIDER_FALLBACK_CHAIN=bitnet,gemini,ollama,lmstudio,openrouter

# Google Gemini (free tier — leave empty to disable)
GEMINI_API_KEY=
GEMINI_MODELS=gemini-2.0-flash,gemini-2.5-flash,gemini-2.5-pro
GEMINI_SAFETY_THRESHOLD=BLOCK_MEDIUM_AND_ABOVE
GEMINI_FLASH_RPM=15
GEMINI_PRO_RPM=2
GEMINI_FLASH_DAILY_LIMIT=1500
GEMINI_PRO_DAILY_LIMIT=50

# Ollama (local server — leave empty to disable)
OLLAMA_HOST=

# LM Studio (local server — leave empty to disable)
LMSTUDIO_HOST=

# OpenRouter (cloud proxy — leave empty to disable)
OPENROUTER_API_KEY=

# ── Rate Limits ──────────────────────────────────────────────────

RATE_LIMIT_PER_MINUTE=60
FREE_TIER_DAILY_REQUESTS=250
MAX_REQUEST_BODY_BYTES=10485760

# Anonymous (unauthenticated) inference limits
ANONYMOUS_DAILY_REQUESTS=25
ANONYMOUS_RATE_PER_MINUTE=5
ANONYMOUS_MAX_TOKENS=256

# ── SIWE Authentication ─────────────────────────────────────────

SIWE_DOMAIN=api.refinet.io
SIWE_CHAIN_ID=1
SIWE_STATEMENT=Sign in to REFINET Cloud. Your Ethereum address is used as a cryptographic key component.
SIWE_SUPPORTED_CHAINS=1,137,42161,10,8453,11155111

# ── Wallet & Identity ───────────────────────────────────────────

WALLET_EMAIL_DOMAIN=cifi.global
ADMIN_WALLET=0xYourAdminWalletAddress

# ── SMTP Bridge ──────────────────────────────────────────────────

SMTP_HOST=127.0.0.1
SMTP_PORT=8025
SMTP_ENABLED=true

# ── Products (embedded build keys) ──────────────────────────────

QUICKCAST_BUILD_KEY=rf_qc_CHANGE_ME
AGENTOS_BUILD_KEY=rf_ao_CHANGE_ME

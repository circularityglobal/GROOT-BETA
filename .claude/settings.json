{
  "permissions": {
    "allow": [
      "Bash(python3 -m pytest *)",
      "Bash(python3 scripts/*)",
      "Bash(cd frontend && npx tsc --noEmit*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(ls *)",
      "Bash(wc *)",
      "Bash(cat .gitignore)",
      "Bash(mkdir -p *)",
      "Bash(chmod +x *)",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep"

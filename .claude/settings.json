      "Bash(rm -rf /)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(cat .env)",
      "Bash(cat *.pem)",
      "Bash(cat *.key)"
    ]
  },
  "env": {
    "REFINET_ENV": "development"
  }
}
